# Global app settings
REGISTRY=docker.io
LISTEN_ADDR=:8090
API_PORT=8090
JWT_SECRET=easyssl-dev-secret

# PostgreSQL settings
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=easyssl
PG_SSLMODE=disable

# Optional: if set, overrides PG_* auto DSN generation in backend
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/easyssl?sslmode=disable
